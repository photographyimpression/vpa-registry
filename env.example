# VPA Registry — Environment Variables
# Copy this file to .env.local for local development
# Set these same variables in Google Cloud Run environment config for production

# ─── Google OAuth (for Partner Login) ────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="PASTE_YOUR_GOOGLE_CLIENT_ID_HERE"
GOOGLE_CLIENT_SECRET="PASTE_YOUR_GOOGLE_CLIENT_SECRET_HERE"

# NextAuth secret — generate a random string: openssl rand -base64 32
AUTH_SECRET="your-generated-secret-here"

# NextAuth canonical URL — MUST match your deployed domain in production
# Locally: http://localhost:3000
# Production: https://vparegistry.com
AUTH_URL=https://vparegistry.com

# NextAuth canonical URL — required in production for OAuth redirects to work
# Must match the deployed domain exactly (no trailing slash)
AUTH_URL=https://vparegistry.com

# ─── Google Sheets (Public Registry Data) ────────────────────────────────────
# Publish your Google Sheet as CSV:
#   File → Share → Publish to web → CSV → Copy link
# Required columns: VPA_Tracking_ID | Cert_Issue_Date | Manufacturer_Name | Device_Metadata | Master_Image_URL | Product_Name | Certified_Image_URL
GOOGLE_SHEETS_CSV_URL=

# ─── n8n Certification Workflow ───────────────────────────────────────────────
# After importing n8n-workflow/vpa-certification-workflow.json into n8n:
#   1. Activate the workflow
#   2. Copy the webhook URL shown in the "Receive Certification Request" node
#   3. Paste it here (format: https://your-n8n.domain.com/webhook/vpa-certify)
N8N_CERTIFICATION_WEBHOOK_URL=

# ─── App URL (used for QR code generation) ────────────────────────────────────
# In production: https://vparegistry.com
# Locally: http://localhost:3000
NEXT_PUBLIC_APP_URL=https://vparegistry.com
