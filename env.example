# VPA Registry — Environment Variables
# Copy this file to .env.local for local development
# Set these same variables in Google Cloud Run environment config for production

# ─── Admin Access ─────────────────────────────────────────────────────────────
# Your email address. Grants access to /admin/* routes (Sales Outreach Pipeline).
# Any logged-in user whose email does NOT match this is redirected away from /admin.
ADMIN_EMAIL=you@yourdomain.com

# ─── Google OAuth (for Partner Login) ────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="PASTE_YOUR_GOOGLE_CLIENT_ID_HERE"
GOOGLE_CLIENT_SECRET="PASTE_YOUR_GOOGLE_CLIENT_SECRET_HERE"

# NextAuth secret — generate a random string: openssl rand -base64 32
AUTH_SECRET="your-generated-secret-here"

# NextAuth canonical URL — MUST match your deployed domain in production
# Locally: http://localhost:3000
# Production: https://vparegistry.com
AUTH_URL=https://vparegistry.com

# ─── Email/Password Partner Login ─────────────────────────────────────────────
# Comma-separated list of approved partner credentials in the format:
#   email:sha256_hex_of_password,email2:sha256_hex_of_password2
#
# To generate a SHA-256 hash for a password (Mac/Linux terminal):
#   echo -n "YourPassword" | sha256sum
#
# Example (password is "SecurePass123"):
#   PARTNER_CREDENTIALS="partner@brand.com:a665a45920422f9d417e4867efdc4fb8a04a1f3fff1fa07e998e86f7f7a27ae3"
#
# Leave empty to disable email/password login (Google-only).
PARTNER_CREDENTIALS=

# ─── Google Sheets (Public Registry Data) ────────────────────────────────────
# Publish your Google Sheet as CSV:
#   File → Share → Publish to web → CSV → Copy link
# Required columns: VPA_Tracking_ID | Cert_Issue_Date | Manufacturer_Name | Device_Metadata | Master_Image_URL | Product_Name | Certified_Image_URL
GOOGLE_SHEETS_CSV_URL=

# ─── n8n Certification Workflow ───────────────────────────────────────────────
# After importing n8n-workflow/vpa-certification-workflow.json into n8n:
#   1. Activate the workflow
#   2. Copy the webhook URL shown in the "Receive Certification Request" node
#   3. Paste it here (format: https://your-n8n.domain.com/webhook/vpa-certify)
N8N_CERTIFICATION_WEBHOOK_URL=

# ─── App URL (used for QR code generation) ────────────────────────────────────
# In production: https://vparegistry.com
# Locally: http://localhost:3000
NEXT_PUBLIC_APP_URL=https://vparegistry.com

# ─── Watermark endpoint security ──────────────────────────────────────────────
# Shared secret for the /api/watermark endpoint (called by n8n).
# Generate: openssl rand -base64 32
# Configure n8n to send this as the X-VPA-Watermark-Secret request header.
# If unset, the endpoint is open (only suitable for local dev).
WATERMARK_SECRET=

# ─── Multi-instance rate limiting (Upstash Redis) ──────────────────────────────
# Optional. When set, /api/certify uses Upstash Redis sliding-window rate limits
# instead of the in-process Map (required when running multiple Cloud Run instances).
# Get these from: https://console.upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── AI image detection ────────────────────────────────────────────────────────
# Controls EXIF-based AI-generated image heuristic in /api/certify.
# off    — disabled (default)
# warn   — log warning but allow certification to proceed
# reject — return 422 Unprocessable Entity for suspected AI images
AI_DETECTION_MODE=off

# ─── Stripe Payments ───────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook secret — from: Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — from: Stripe Dashboard → Products → each plan's price
STRIPE_STARTER_MONTHLY_PRICE_ID=price_...
STRIPE_STARTER_ANNUAL_PRICE_ID=price_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...

# Optional: forward Stripe events to n8n for CRM/notification automation
N8N_STRIPE_WEBHOOK_URL=

# ─── Partner Registration Workflow ────────────────────────────────────────────
# n8n webhook URL for new access requests (from /register page).
# If unset, registrations are only logged to stdout.
N8N_REGISTER_WEBHOOK_URL=

# ─── Sales Outreach Module ─────────────────────────────────────────────────────
# Powers the AI-driven partner acquisition pipeline at /dashboard/outreach.

# Anthropic API key — used to generate personalised outreach emails via Claude.
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Resend API key — used to send outreach and follow-up emails.
# Free tier: 3,000 emails/month. Get from: https://resend.com → API Keys
RESEND_API_KEY=re_...

# Sender email address shown in outreach emails.
# Must be a verified domain in your Resend account.
OUTREACH_FROM_EMAIL=partners@vparegistry.com

# Secret token for the automated follow-up cron endpoint (/api/outreach/followup?token=...).
# Generate: openssl rand -base64 32
OUTREACH_CRON_SECRET=
